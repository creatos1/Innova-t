# Firebase web config. Estas variables son publicas del cliente web, pero deben
# coincidir con el proyecto real de Firebase usado en produccion.
VITE_FIREBASE_API_KEY=tu_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# IA cliente. Mistral se llama por serverless para no exponer API keys.
VITE_ENABLE_FIREBASE_AI=false
VITE_GEMINI_MODEL=gemini-2.5-flash-lite
VITE_FIREBASE_AI_APP_CHECK=false
VITE_ENABLE_MISTRAL_AI=true
VITE_MISTRAL_MODEL=mistral-server
VITE_MISTRAL_PROXY_URL=/api/mistral-class-plan
VITE_MISTRAL_MONTHLY_LIMIT=1000

# Reloj Mexico para Show time. Es publica y no requiere key.
VITE_MEXICO_TIME_API_URL=https://worldtimeapi.org/api/timezone/America/Mexico_City

# Solo en Vercel/serverless. NO usar prefijo VITE_ para secretos.
MISTRAL_API_KEY=tu_mistral_api_key
MISTRAL_MODEL=mistral-small-latest
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions

# Firebase Admin para funciones privadas del servidor.
# Opcion recomendada: pega el JSON completo del service account como valor secreto en Vercel.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"tu-proyecto","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com","client_id":"..."}

# Opcion alternativa si no usas FIREBASE_SERVICE_ACCOUNT_JSON:
# FIREBASE_PROJECT_ID=tu-proyecto
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
