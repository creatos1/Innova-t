rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function role() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && userDoc().data.rol != null
        ? userDoc().data.rol
        : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isTeacher() {
      return role() == 'teacher';
    }

    function isStaff() {
      return isAdmin() || isTeacher();
    }

    function profileOwnsStudent(studentId) {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && userDoc().data.studentId == studentId;
    }

    function studentEmailMatchesAuth(studentId) {
      return signedIn()
        && exists(/databases/$(database)/documents/estudiantes/$(studentId))
        && get(/databases/$(database)/documents/estudiantes/$(studentId)).data.email == request.auth.token.email;
    }

    function ownsStudent(studentId) {
      return signedIn()
        && exists(/databases/$(database)/documents/estudiantes/$(studentId))
        && (
          get(/databases/$(database)/documents/estudiantes/$(studentId)).data.uid == request.auth.uid
          || profileOwnsStudent(studentId)
          || studentEmailMatchesAuth(studentId)
        );
    }

    function currentStudentId() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && userDoc().data.studentId is string
        ? userDoc().data.studentId
        : '';
    }

    function isStudentAutoClassCreate() {
      return signedIn()
        && request.resource.data.reservationSource == 'student-auto'
        && request.resource.data.status == 'pendiente_asignacion'
        && request.resource.data.teacherId == ''
        && request.resource.data.teacherName == ''
        && request.resource.data.durationHours == 1
        && request.resource.data.reservationBlockHours >= 1
        && request.resource.data.reservationBlockHours <= 3
        && request.resource.data.studentIds.size() == 1
        && ownsStudent(request.resource.data.studentIds[0]);
    }

    function isStudentClassRosterAdd() {
      let studentId = currentStudentId();
      return studentId != ''
        && ownsStudent(studentId)
        && resource.data.reservationSource == 'student-auto'
        && resource.data.status == 'pendiente_asignacion'
        && resource.data.teacherId == ''
        && request.resource.data.teacherId == ''
        && request.resource.data.teacherName == ''
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['studentIds', 'updatedAt'])
        && !resource.data.studentIds.hasAny([studentId])
        && request.resource.data.studentIds.hasAny([studentId])
        && request.resource.data.studentIds.hasAll(resource.data.studentIds)
        && request.resource.data.studentIds.size() == resource.data.studentIds.size() + 1
        && request.resource.data.studentIds.size() <= 8;
    }

    function isStudentClassRosterRemove() {
      let studentId = currentStudentId();
      return studentId != ''
        && ownsStudent(studentId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['studentIds', 'updatedAt'])
        && resource.data.studentIds.hasAny([studentId])
        && !request.resource.data.studentIds.hasAny([studentId])
        && resource.data.studentIds.hasAll(request.resource.data.studentIds)
        && resource.data.studentIds.size() == request.resource.data.studentIds.size() + 1;
    }

    function isStudentAutoClassDelete() {
      let studentId = currentStudentId();
      return studentId != ''
        && ownsStudent(studentId)
        && resource.data.reservationSource == 'student-auto'
        && resource.data.status == 'pendiente_asignacion'
        && resource.data.teacherId == ''
        && resource.data.studentIds.size() == 1
        && resource.data.studentIds.hasAny([studentId]);
    }

    function isBootstrapAdmin(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.auth.token.email == 'admin@innova-t.com'
        && request.resource.data.rol == 'admin';
    }

    function isStudentFirstLoginUser(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.rol == 'estudiante'
        && request.resource.data.studentId is string
        && exists(/databases/$(database)/documents/estudiantes/$(request.resource.data.studentId))
        && get(/databases/$(database)/documents/estudiantes/$(request.resource.data.studentId)).data.email == request.auth.token.email;
    }

    function isTeacherFirstLoginUser(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.rol == 'teacher'
        && request.resource.data.teacherId is string
        && exists(/databases/$(database)/documents/teachers/$(request.resource.data.teacherId))
        && get(/databases/$(database)/documents/teachers/$(request.resource.data.teacherId)).data.email == request.auth.token.email;
    }

    function isLimitedLoginLookup() {
      return request.query.limit != null && request.query.limit <= 1;
    }

    function isStudentUidClaim() {
      return signedIn()
        && resource.data.email == request.auth.token.email
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['uid', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid;
    }

    function isTeacherUidClaim() {
      return signedIn()
        && resource.data.email == request.auth.token.email
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['uid', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid;
    }

    function isLoginIdStudentClaim() {
      return signedIn()
        && request.resource.data.role == 'estudiante'
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.studentId is string
        && exists(/databases/$(database)/documents/estudiantes/$(request.resource.data.studentId))
        && get(/databases/$(database)/documents/estudiantes/$(request.resource.data.studentId)).data.email == request.auth.token.email;
    }

    function isLoginIdTeacherClaim() {
      return signedIn()
        && request.resource.data.role == 'teacher'
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.teacherId is string
        && exists(/databases/$(database)/documents/teachers/$(request.resource.data.teacherId))
        && get(/databases/$(database)/documents/teachers/$(request.resource.data.teacherId)).data.email == request.auth.token.email;
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin()
        || isBootstrapAdmin(userId)
        || isStudentFirstLoginUser(userId)
        || isTeacherFirstLoginUser(userId);
      allow update: if isAdmin()
        || isStudentFirstLoginUser(userId)
        || isTeacherFirstLoginUser(userId);
      allow delete: if isAdmin();
    }

    match /loginIds/{loginId} {
      allow read: if true;
      allow create: if isAdmin() || isLoginIdStudentClaim() || isLoginIdTeacherClaim();
      allow update: if isAdmin()
        || (
          (isLoginIdStudentClaim() || isLoginIdTeacherClaim())
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['uid', 'updatedAt', 'email', 'role', 'studentId', 'teacherId', 'publicId', 'fullName', 'name'])
        );
      allow delete: if isAdmin();
    }

    match /estudiantes/{studentId} {
      allow get: if isStaff() || ownsStudent(studentId);
      allow list: if isStaff() || isLimitedLoginLookup();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isStudentUidClaim();
    }

    match /niveles/{levelId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /lecciones/{lessonId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow get: if signedIn();
      allow list: if signedIn() || isLimitedLoginLookup();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isTeacherUidClaim();
    }

    match /classrooms/{classroomId} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /bloqueos/{blockoutId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /clases/{classId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isStudentAutoClassCreate();
      allow delete: if isAdmin() || isStudentAutoClassDelete();
      allow update: if isAdmin() || isStudentClassRosterAdd() || isStudentClassRosterRemove();
    }

    match /asistencias/{attendanceId} {
      allow read: if isStaff() || ownsStudent(resource.data.studentId);
      allow create: if isStaff();
      allow update: if isStaff()
        || (
          ownsStudent(resource.data.studentId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['absenceNoticeAt', 'updatedAt'])
        );
      allow delete: if isAdmin();
    }

    match /pagos/{paymentId} {
      allow read: if isStaff() || ownsStudent(resource.data.studentId);
      allow write: if isAdmin();
    }

    match /calificaciones/{gradeId} {
      allow read: if isStaff() || ownsStudent(resource.data.studentId);
      allow write: if isAdmin();
    }

    match /becaEventos/{eventId} {
      allow read: if isStaff() || ownsStudent(resource.data.studentId);
      allow write: if isAdmin();
    }

    match /aiRecommendations/{recommendationId} {
      allow read: if isStaff() || ownsStudent(resource.data.studentId);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /authDeletionRequests/{requestId} {
      allow read, write: if isAdmin();
    }
  }
}
